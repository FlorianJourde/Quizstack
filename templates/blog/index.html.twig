{% extends 'layout.html.twig' %}

{% set title = 'Blog' %}

{% block meta_description %}Meta description{% endblock %}

{% block body %}

    {{ include('partials/banner.html.twig', {'color': 'blue', 'animate' : 'animate'}) }}

    <div class="wrapper">
        <div class="page-header-container">
            <h1 class="big-title grow">Blog</h1>
            <div class="buttons-container">
                <a class="button button-action" href="{{ path('article_new') }}">
                    <span class="material-icons">add</span>
                </a>
            </div>
        </div>
    </div>

    <div class="wrapper wrapper-large">

        <h1>Blog</h1>

        {% if articles is empty %}
            <p>No articles found.</p>
        {% else %}

            {% for article in articles %}
                <article>

                    <h2>
                        {#                        <a href="#"> #}
                        {#                            {{ article.title }} #}
                        {#                        </a> #}

                        <a href="{{ path('article', { slug: article.slug }) }}">
                            {{ article.title }}
                        </a>
                    </h2>

                    <p>
                        Published on
                        {{ article.creationDate|date('Y-m-d') }}
                    </p>

                    {% if article.image %}
                        <img
                                src="{{ asset('uploads/articles/' ~ article.image) }}"
                                alt="{{ article.title }}"
                                width="300"
                        >
                    {% endif %}

                </article>

                <hr>

            {% endfor %}

        {% endif %}
    </div>
{% endblock %}