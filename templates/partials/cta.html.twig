{% set color = color|default('green') %}

{% set bgClasses = {
    'green': 'bg-green-secondary',
    'blue':  'bg-blue-primary',
} %}

{% set shadowClasses = {
    'green': 'shadow-[0_0_105px_hsl(77deg_86%_35%_/_10%),_0_0_125px_hsl(77deg_86%_35%_/_10%),_0_0_150px_hsl(77deg_86%_35%_/_10%)]',
    'blue':  'shadow-[0_0_105px_hsl(200deg_86%_35%_/_10%),_0_0_125px_hsl(200deg_86%_35%_/_10%),_0_0_150px_hsl(200deg_86%_35%_/_10%)]',
} %}

{% set bgClass = bgClasses[color]|default(bgClasses['green']) %}
{% set shadowClass = shadowClasses[color]|default(shadowClasses['green']) %}

<div class="wrapper pt-spacing-large-primary pb-spacing-large-primary">
    <section class="flex flex-col md:flex-row box cta p-spacing-large-secondary gap-spacing-large-secondary {{ bgClass }} rounded-radius-primary items-start md:items-center {{ shadowClass }}">
        <div class="flex flex-col gap-4 max-w-[400px]">
            <h2 class="text-3xl font-bold">Level up your dev skills</h2>
            <p class="md:text-lg opacity-75">Measure your knowledge, track your progress, and fill the gaps in HTML, CSS, JavaScript, PHP, SQL and more with short, focused quizzes.</p>
        </div>
        <div class="flex grow self-end md:self-center justify-center">
            <a href="{{ path('quiz') }}" class="button button-primary button-large border-none button-dark-grey whitespace-nowrap md:text-xl">Start the quiz</a>
        </div>
    </section>
</div>